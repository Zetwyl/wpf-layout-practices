<Window x:Class="Task_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBox x:Name="t1" />
            <TextBox x:Name="t2" Text="{Binding ElementName=t1, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Slider x:Name="slider1" />
            <Slider x:Name="slider2" Value="{Binding ElementName=slider1, Path=Value}" />
        </StackPanel>
    </Grid>
</Window>
