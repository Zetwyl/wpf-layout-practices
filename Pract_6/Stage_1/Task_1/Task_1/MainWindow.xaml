<Window x:Class="Task_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task_1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    <Grid>
        
        <Slider Minimum="8" Maximum="30" ValueChanged="Slider_ValueChanged" />
        <StackPanel Margin="0,30,0,0">
            <TextBlock x:Name="Message" FontSize="{Binding ElementName=SliderFontSize, Path=Value}">
Пример WPF-приложения для демонстрации привязки данных
            </TextBlock>
        </StackPanel>
        
    </Grid>
</Window>
