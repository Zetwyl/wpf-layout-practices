<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Управление компьютером" Height="800" Width="800">
    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 1. Главное меню -->
        <Menu Grid.Row="0" Background="White" Padding="0,2" Grid.ColumnSpan="2">
            <MenuItem Header="Файл">
                <MenuItem Header="Опции..."></MenuItem>
                <Separator/>
                <MenuItem Header="Выход"></MenuItem>
            </MenuItem>
            <MenuItem Header="Действие" />
            <MenuItem Header="Вид" />
            <MenuItem Header="Справка" />
        </Menu>

        <!-- Панель инструментов -->
        <ToolBar Grid.Row="1" Height="25" VerticalAlignment="Stretch" Grid.ColumnSpan="2">
            <Button IsEnabled="False">
                <TextBlock Text="←" FontSize="11"/>
            </Button>
            <Button IsEnabled="False">
                <TextBlock Text="→" FontSize="11"/>
            </Button>
            <Separator/>

            <Button IsEnabled="True">
                <TextBlock Text="🗔" FontSize="11"/>
            </Button>
            <Button>
                <TextBlock Text="📄" FontSize="11"/>
            </Button>
            <Separator/>

            <Button>
                <TextBlock Text="❓" FontSize="11"/>
            </Button>
            <Button IsEnabled="True">
                <TextBlock Text="🗔" FontSize="11"/>
            </Button>
        </ToolBar>

        <!-- Левая часть -->
        <TreeView Grid.Row="2" Margin="0,5,1.5,0">
            <TreeViewItem Header="💻 Управление компьютером (локальным)" IsExpanded="True">
                <TreeViewItem.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Подключиться к другому компьютеру" />
                        <Separator/>
                        <MenuItem Header="Помощь" />
                    </ContextMenu>
                </TreeViewItem.ContextMenu>

                <TreeViewItem Header="🔧 Служебные программы" IsExpanded="True">
                    <TreeViewItem.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Помощь" />
                        </ContextMenu>
                    </TreeViewItem.ContextMenu>
                    
                    <TreeViewItem Header="🕒 Планировщик заданий" IsExpanded="True">
                        <TreeViewItem Header="📁 Библиотека планировщика заданий"></TreeViewItem>
                    </TreeViewItem>
                    
                    <TreeViewItem Header="🕒 Просмотр событий" IsExpanded="True">
                        <TreeViewItem.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Открыть сохраненные логи" />
                                <MenuItem Header="Помощь" />
                            </ContextMenu>
                        </TreeViewItem.ContextMenu>
                        
                        <TreeViewItem Header="📁 Настраиваемые представления"/>
                        <TreeViewItem Header="📁 Журналы Windows"/>
                        <TreeViewItem Header="📁 Журналы приложений и служб"/>
                        <TreeViewItem Header="📁 Подписки"/>
                    </TreeViewItem>

                    <TreeViewItem Header="📁 Общие папки" IsExpanded="True">
                        <TreeViewItem Header="📁 Общие ресурсы"/>
                        <TreeViewItem Header="📁 Сеансы"/>
                        <TreeViewItem Header="📁 Открытые файлы"/>
                    </TreeViewItem>

                    <TreeViewItem Header="👥 Локальные пользователи и группы" IsExpanded="True">
                        <TreeViewItem Header="📁 Пользователи">
                            <TreeViewItem.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Новый пользователь" />
                                    <MenuItem Header="Обновить" />
                                    <MenuItem Header="Помощь" />
                                </ContextMenu>
                            </TreeViewItem.ContextMenu>
                        </TreeViewItem>
                        <TreeViewItem Header="📁 Группы">
                            <TreeViewItem.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Новая группа" />
                                    <MenuItem Header="Обновить" />
                                    <MenuItem Header="Помощь" />
                                </ContextMenu>
                            </TreeViewItem.ContextMenu>
                        </TreeViewItem>
                    </TreeViewItem>

                    <TreeViewItem Header="📈 Производительность" IsExpanded="True">
                        <TreeViewItem Header="📁 Средства наблюдения"/>
                        <TreeViewItem Header="📁 Группы сборщиков данных"/>
                        <TreeViewItem Header="📁 Отчеты"/>
                    </TreeViewItem>

                    <TreeViewItem Header="🖨️ Диспетчер устройств"/>
                </TreeViewItem>

                <TreeViewItem Header="🗄️ Запоминающие устройства" IsExpanded="True">
                    <TreeViewItem.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Помощь" />
                        </ContextMenu>
                    </TreeViewItem.ContextMenu>
                    
                    <TreeViewItem Header="💿 Управление дисками"/>
                </TreeViewItem>

                <TreeViewItem Header="⚙️ Службы и приложения" IsExpanded="True">
                    <TreeViewItem.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Помощь" />
                        </ContextMenu>
                    </TreeViewItem.ContextMenu>
                    
                    <TreeViewItem Header="⚙️ Службы"/>
                    <TreeViewItem Header="🗃️ Управляющий элемент WMI"/>
                </TreeViewItem>
                
            </TreeViewItem>
        </TreeView>


        <!-- Правая часть-->
        <ListView Grid.Row="2" Grid.Column="2" Margin="1.5,5,0,0">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Помощь"/>
                </ContextMenu>
            </ListView.ContextMenu>
            
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Имя" Width="300"/>
                </GridView>
            </ListView.View>
            
            <ListViewItem>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/image0.png" Margin="0,0,5,0" />
                    <TextBlock Text="Служебные программы"/>
                </StackPanel>
            </ListViewItem>
            
            <ListViewItem>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/image1.png" Margin="0,0,5,0" />
                    <TextBlock Text="Запоминающие устройства"/>
                </StackPanel>
            </ListViewItem>
            
            <ListViewItem>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/image2.png" Margin="0,0,5,0" />
                    <TextBlock Text="Службы и приложения"/>
                </StackPanel>
            </ListViewItem>
        </ListView>

        <!-- Нижняя часть-->
        <TextBlock Grid.Row="3"
                   Grid.ColumnSpan="2"
                   Text="Содержит команды управления видом этого окна."
                   Background="#F0F0F0"
                   Padding="5"/>
    </Grid>
</Window>
